{
  "name": "cec-backend",
  "version": "1.0.0",
  "description": "Sistema Administrativo da Casa do Estudante de Caicó - Backend",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "NODE_OPTIONS='--no-deprecation' react-scripts start",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/config/seed.js",
    "test": "jest --coverage --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/migrate.js",
      "!src/config/seed.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
